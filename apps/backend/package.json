{
	"name": "@ksi-core/backend",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"test": "echo \"Error: no test specified\" && exit 1",
		"dev": "bun run --watch src/index.ts",
		"db:generate": "bunx dotenv -e ../../.env -- bunx --bun drizzle-kit generate",
		"db:migrate": "bunx dotenv -e ../../.env -- bunx --bun drizzle-kit migrate"
	},
	"exports": {
		".": "./src/index.ts",
		"./*": "./src/*.ts"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.0",
		"@paralleldrive/cuid2": "^3.0.4",
		"@sinclair/typebox": "^0.34.41",
		"@types/ms": "^2.1.0",
		"better-auth": "^1.3.34",
		"bun": "^1.3.1",
		"discord.js": "^14.24.2",
		"drizzle-orm": "^0.44.7",
		"elysia": "^1.4.16",
		"ms": "^2.1.3",
		"pg": "^8.16.3",
		"shared": "workspace:*"
	},
	"devDependencies": {
		"@types/bun": "^1.3.1",
		"bun-types": "^1.3.0",
		"dotenv-cli": "^11.0.0",
		"drizzle-kit": "^0.31.6"
	},
	"module": "src/index.js"
}
