{
  "name": "ksi-website",
  "version": "0.0.1",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "clean": "rm -rf node_modules apps/api/node_modules apps/launcher/node_modules app/website/node_modules",
    "db:generate": "cd apps/backend && bun run db:generate",
    "db:migrate": "cd apps/backend && bun run db:migrate",
    "dev:frontend": "cd apps/frontend && bun run dev",
    "dev:backend": "cd apps/backend && bun dotenv -e ../../.env -- bun --hot run dev",
    "dev": "concurrently -n \"backend,frontend\" -c \"bgGreen,bgBlue\" \"bun run dev:backend\" \"bun run dev:frontend\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "bun-types": "^1.3.12",
    "concurrently": "^8.2.2",
    "dotenv": "^17.4.2",
    "oxfmt": "^0.52.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
